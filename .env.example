# ============================================================
# GoniCore — Environment Configuration Template
# ------------------------------------------------------------
# 1. Copy this file to .env
# 2. Fill in your values
# 3. NEVER commit .env to version control
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

APP_NAME=GoniCore
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# PDO driver: mysql | pgsql | sqlite
DB_DRIVER=mysql

DB_HOST=127.0.0.1
DB_PORT=3306

# Database name (or absolute path for SQLite: /app/storage/db.sqlite)
DB_NAME=gonicore

DB_USER=root
DB_PASS=

# Character set (MySQL / MariaDB only)
DB_CHARSET=utf8mb4

# ------------------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------------------

# Generate a strong secret:  php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
# MUST be at least 32 characters.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Token lifetime in seconds (default: 3600 = 1 hour)
JWT_TTL=3600

# ------------------------------------------------------------
# Media storage
# ------------------------------------------------------------

# Absolute or relative-to-project path where uploads are stored.
# Default: storage/media  (relative to project root)
MEDIA_STORAGE_PATH=storage/media
