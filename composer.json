{
    "name": "goni/gonicore",
    "description": "Framework-agnostic, strictly modular, API-first Headless CMS",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "GoniCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GoniCore\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable"
}
